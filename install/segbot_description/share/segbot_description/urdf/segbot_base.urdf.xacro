<?xml version="1.0"?>
<root xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Namespace prefix for multi-robot -->
  <xacro:arg name="prefix" default="r1"/>

  <!-- Include wheel macro -->
  <xacro:include filename="$(find segbot_description)/urdf/segbot_wheel.urdf.xacro"/>

  <!-- Macro definition -->
  <xacro:macro name="segbot" params="prefix">

    <!-- root link -->
    <link name="${prefix}_base_footprint">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.001 0.001 0.001"/>
        </geometry>
      </visual>
    </link>

    <joint name="${prefix}_base_footprint_joint" type="fixed">
      <origin xyz="0.0 0 0.2165" rpy="0 0 0"/>
      <parent link="${prefix}_base_footprint"/>
      <child link="${prefix}_base_link"/>
    </joint>

    <!-- base_link -->
    <link name="${prefix}_base_link">
      <xacro:segbot_base_link_inertial/>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find segbot_description)/meshes/rmp50-base-link.stl"
                scale="0.0254 0.0254 0.0254"/>
        </geometry>
      </visual>
      <xacro:segbot_base_link_collision/>
    </link>

    <xacro:gazebo_laser_obstacle/>
    <xacro:gazebo_segbot_base_link_surface/>

    <!-- castor support -->
    <joint name="${prefix}_base_caster_support_joint" type="continuous">
      <origin xyz="-0.3292 0 -0.0485" rpy="0 0 0"/>
      <parent link="${prefix}_base_link"/>
      <child link="${prefix}_base_caster_support_link"/>
      <axis xyz="0 0 1"/>
    </joint>

    <transmission name="${prefix}_base_caster_support_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <actuator name="${prefix}_base_caster_support_motor"/>
      <joint name="${prefix}_base_caster_support_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <mechanicalReduction>1.0</mechanicalReduction>
    </transmission>

    <link name="${prefix}_base_caster_support_link">
      <inertial>
        <mass value="1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.00375" ixy="0.0" ixz="0.0"
                 iyy="0.00375" iyz="0.0"
                 izz="0.00375"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find segbot_description)/meshes/rmp50-castor-link.stl"
                scale="0.0254 0.0254 0.022"/>
        </geometry>
      </visual>
      <xacro:segbot_castor_support_link_collision/>
    </link>

    <gazebo reference="${prefix}_base_caster_support_link">
      <mu1 value="100.0"/>
      <mu2 value="100.0"/>
      <kp  value="1000000.0"/>
      <kd  value="1.0"/>
    </gazebo>

    <!-- castor wheel -->
    <joint name="${prefix}_caster_wheel_joint" type="continuous">
      <origin xyz="-0.0397 0 -0.0918" rpy="0 0 0"/>
      <parent link="${prefix}_base_caster_support_link"/>
      <child link="${prefix}_caster_wheel_link"/>
      <axis xyz="0 1 0"/>
    </joint>

    <transmission name="${prefix}_caster_wheel_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <actuator name="${prefix}_caster_wheel_motor"/>
      <joint name="${prefix}_caster_wheel_joint">
        <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      </joint>
      <mechanicalReduction>1.0</mechanicalReduction>
    </transmission>

    <link name="${prefix}_caster_wheel_link">
      <inertial>
        <mass value="2"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.003" ixy="0.0" ixz="0.0"
                 iyy="0.00581" iyz="0.0"
                 izz="0.003"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find segbot_description)/meshes/rmp50-castor-wheel.stl"
                scale="0.022 0.022 0.022"/>
        </geometry>
      </visual>
      <xacro:segbot_castor_wheel_link_collision/>
    </link>

    <xacro:gazebo_segbot_castor_wheel_link_surface/>

    <!-- left wheel -->
    <xacro:segbot_wheel prefix="${prefix}" suffix="left" parent="base_link">
      <origin xyz="0 0.2689 0.0239" rpy="0 0 0"/>
    </xacro:segbot_wheel>

    <!-- right wheel -->
    <xacro:segbot_wheel prefix="${prefix}" suffix="right" parent="base_link">
      <origin xyz="0 -0.2689 0.0239" rpy="0 0 0"/>
    </xacro:segbot_wheel>

  </xacro:macro>
</root>
